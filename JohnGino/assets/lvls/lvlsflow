level_structures = {}


def build_scenario_for_level(lvl_id):
    random.seed(lvl_id * 105)
    structures = []
    current_x = -3000
    while current_x < 6000:
        width = random.randint(200, 380)
        height = random.randint(220, 500)
        struct_type = 2 if random.random() < 0.25 else 1
        structures.append({
            "x": current_x, "width": width, "height": height, "type": struct_type,
            "color_offset": random.randint(-15, 15), "detail_seed": random.randint(0, 1000)
        })
        current_x += width - random.randint(0, 20)
    return structures


for i in range(1, 7):
    level_structures[i] = build_scenario_for_level(i)


# Funzioni degli sfondi
def draw_background_skyline(surface, lvl_id, cam_x):
    color = LEVELS[lvl_id]["bg_color"]
    if lvl_id == 1:
        v_px = -(cam_x * 0.08) % 2000
        for i in range(-1, 2):
            base_x = v_px + (i * 2000) + 150
            pygame.draw.polygon(surface, color,
                                [(base_x, 500), (base_x + 350, 320), (base_x + 650, 290), (base_x + 1100, 500)])
    elif lvl_id == 6:
        v_px = -(cam_x * 0.07) % 1600
        for i in range(-1, 2):
            base_x = v_px + (i * 1600) + 300
            pygame.draw.ellipse(surface, color, (base_x - 100, 300, 800, 300))


def draw_pizzeria_sign(surface, x, floor_y, struct, text_str):
    w = struct["width"]
    sign_w = int(w * 0.85)
    sign_x = x + (w - sign_w) // 2
    sign_y = floor_y - 125
    pygame.draw.rect(surface, (130, 30, 20), (sign_x, sign_y, sign_w, 40), border_radius=4)
    pygame.draw.rect(surface, (240, 218, 175), (sign_x + 3, sign_y + 3, sign_w - 6, 34), border_radius=4)
    ts = pygame.font.SysFont("serif", 16, bold=True).render(text_str.upper(), True, (90, 20, 12))
    surface.blit(ts, (sign_x + (sign_w - ts.get_width()) // 2, sign_y + (40 - ts.get_height()) // 2))


def draw_foreground_level(surface, lvl_id, cam_x):
    level = LEVELS[lvl_id]
    floor_y = 580
    for s in level_structures[lvl_id]:
        screen_x = s["x"] - cam_x
        while screen_x < -s["width"] - 300: screen_x += 9000
        while screen_x > SCREEN_WIDTH + 300: screen_x -= 9000
        if screen_x + s["width"] < -100 or screen_x > SCREEN_WIDTH + 100: continue

        bc = level["fg_color"]
        col = (max(0, min(255, bc[0] + s["color_offset"])), max(0, min(255, bc[1] + s["color_offset"])),
               max(0, min(255, bc[2] + s["color_offset"])))
        pygame.draw.rect(surface, col, (screen_x, floor_y - s["height"], s["width"], s["height"]))
        pygame.draw.rect(surface, (30, 30, 30), (screen_x, floor_y - s["height"], s["width"], s["height"]), 2)

        if s["type"] == 2:
            pizzeria_name = level.get("pizzeria_suffix")
            if pizzeria_name:
                draw_pizzeria_sign(surface, screen_x, floor_y, s, f"Pizzeria {pizzeria_name}")


