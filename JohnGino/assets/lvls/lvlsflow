def draw_button(surface, rect, text, is_hovered, bg_color=(70, 55, 45), text_color=(240, 230, 215)):
    # Effetto feedback visivo al passaggio del mouse
    actual_bg = (int(bg_color[0] * 1.2), int(bg_color[1] * 1.2), int(bg_color[2] * 1.2)) if is_hovered else bg_color
    pygame.draw.rect(surface, actual_bg, rect, border_radius=8)
    pygame.draw.rect(surface, (200, 170, 130), rect, 2, border_radius=8)
    txt_surf = font_ui.render(text, True, text_color)
    surface.blit(txt_surf, (rect.x + (rect.width - txt_surf.get_width()) // 2,
                            rect.y + (rect.height - txt_surf.get_height()) // 2))


