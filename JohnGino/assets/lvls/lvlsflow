# Classe particelle
class Particle:
    def __init__(self, level_type):
        self.reset(level_type, True)

    def reset(self, level_type, init_anywhere=False):
        self.level_type = level_type
        self.x = random.randint(0, SCREEN_WIDTH)
        self.y = random.randint(0, SCREEN_HEIGHT) if init_anywhere else (
            -10 if level_type not in ["smoke_gold"] else SCREEN_HEIGHT + 10)

        if level_type == "water":
            self.y = random.randint(520, 720)
            self.vx = random.uniform(-1, 1)
            self.vy = random.uniform(-0.5, -2)
            self.size = random.randint(2, 4)
            self.color = (180, 205, 225, 130)
        elif level_type == "dust":
            self.vx = random.uniform(-0.4, 0.4)
            self.vy = random.uniform(0.2, 0.7)
            self.size = random.randint(1, 3)
            self.color = (255, 225, 170, 95)
        elif level_type == "smoke":
            self.vx = random.uniform(-2, -0.5)
            self.vy = random.uniform(0.8, 1.8)
            self.size = random.randint(5, 11)
            self.color = (55, 52, 52, 140)
        elif level_type == "drip":
            self.vx = random.uniform(-0.1, 0.1)
            self.vy = random.uniform(4, 8)
            self.size = random.randint(1, 3)
            self.color = (60, 180, 140, 160)
        elif level_type == "sparks":
            self.vx = random.uniform(-2, 2)
            self.vy = random.uniform(1.5, 4)
            self.size = random.randint(1, 4)
            self.color = (255, 140, 35, 210)
        elif level_type == "smoke_gold":
            self.y = random.randint(150, 600) if init_anywhere else SCREEN_HEIGHT - 100
            self.vx = random.uniform(-0.6, 0.6)
            self.vy = random.uniform(-0.4, -1.2)
            self.size = random.randint(2, 7)
            self.color = (225, 185, 65, 170) if random.random() < 0.35 else (170, 170, 180, 75)

        self.surf = pygame.Surface((self.size * 2, self.size * 2), pygame.SRCALPHA)
        pygame.draw.circle(self.surf, self.color, (self.size, self.size), self.size)

    def update(self, cam_delta):
        self.x -= cam_delta * 0.8
        self.x += self.vx
        self.y += self.vy
        if (self.y > SCREEN_HEIGHT + 20 or self.y < -20 or self.x < -20 or self.x > SCREEN_WIDTH + 20):
            self.reset(self.level_type)

    def draw(self, surface):
        surface.blit(self.surf, (int(self.x - self.size), int(self.y - self.size)))


