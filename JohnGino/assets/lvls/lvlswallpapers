def draw_foreground_level(surface, lvl_id, cam_x):
    level = LEVELS[lvl_id]
    structs = level_structures[lvl_id]

    floor_y = 580
    if lvl_id == 4: floor_y = 610

    parallax_factor = 1.0
    total_world_width = 9000  # Mappa e scorrimento

    for s in structs:
        screen_x = s["x"] - (cam_x * parallax_factor)

        # Scorrimento continuo
        while screen_x < -s["width"] - 300:
            screen_x += total_world_width
        while screen_x > SCREEN_WIDTH + 300:
            screen_x -= total_world_width

        # Disegno elementi solo visibili - anti lag
        if screen_x + s["width"] < -100 or screen_x > SCREEN_WIDTH + 100:
            continue

        base_col = level["fg_color"]
        col = (
            max(0, min(255, base_col[0] + s["color_offset"])),
            max(0, min(255, base_col[1] + s["color_offset"])),
            max(0, min(255, base_col[2] + s["color_offset"]))
        )

        if lvl_id == 1:  
            if s["type"] == 3:  # Nave cargo a vapore
                ship_rect = pygame.Rect(screen_x, floor_y - 200, s["width"] + 100, 200)

                # Scafo nero e rosso 
                pygame.draw.rect(surface, (25, 25, 28), ship_rect, border_top_left_radius=45)
                pygame.draw.rect(surface, (90, 30, 25), (ship_rect.x, ship_rect.y + 130, ship_rect.width, 70),
                                 border_top_left_radius=10)

                # Oblò 
                for ox in range(ship_rect.x + 60, ship_rect.x + ship_rect.width - 40, 45):
                    pygame.draw.circle(surface, (245, 225, 150), (ox, ship_rect.y + 70), 8)
                    pygame.draw.circle(surface, (15, 15, 15), (ox, ship_rect.y + 70), 8, 2)

                # Ciminiere 
                pygame.draw.rect(surface, (150, 45, 35), (ship_rect.x + 80, ship_rect.y - 75, 40, 75))
                pygame.draw.rect(surface, (15, 15, 15), (ship_rect.x + 80, ship_rect.y - 75, 40, 15))
                pygame.draw.rect(surface, (150, 45, 35), (ship_rect.x + 190, ship_rect.y - 75, 40, 75))
                pygame.draw.rect(surface, (15, 15, 15), (ship_rect.x + 190, ship_rect.y - 75, 40, 15))

                # Nome sulla poppa
                txt = font_ui.render("SS VESUVIO", True, (230, 225, 215))
                surface.blit(txt, (ship_rect.x + 40, ship_rect.y + 145))

                # Cime di ormeggio 
                bitta_x = ship_rect.x - 25
                pygame.draw.rect(surface, (35, 35, 35), (bitta_x, floor_y - 25, 16, 25), border_radius=3)
                pygame.draw.line(surface, (15, 12, 10), (bitta_x + 8, floor_y - 15),
                                 (ship_rect.x + 60, ship_rect.y + 120), 3)

                # Casse di pomodoro sporche
                draw_rotten_tomato_crates(surface, ship_rect.x + ship_rect.width - 50, floor_y, s["detail_seed"])
            else:
                draw_vintage_building(surface, screen_x, floor_y, s, col, level)
                if s["detail_seed"] % 3 == 0:
                    draw_rotten_tomato_crates(surface, screen_x + 25, floor_y, s["detail_seed"])

        elif lvl_id == 2:  
            if s["type"] == 3:
                draw_vintage_building(surface, screen_x, floor_y, s, col, level)
                stand_x = screen_x + 30
                stand_y = floor_y - 70
                pygame.draw.rect(surface, (180, 45, 35), (stand_x, stand_y, 110, 20))
                pygame.draw.rect(surface, (235, 235, 235), (stand_x + 20, stand_y, 70, 20))
                pygame.draw.line(surface, (110, 75, 45), (stand_x, stand_y), (stand_x, floor_y), 3)
                pygame.draw.line(surface, (110, 75, 45), (stand_x + 110, stand_y), (stand_x + 110, floor_y), 3)
                pygame.draw.ellipse(surface, (150, 55, 45), (stand_x + 10, floor_y - 25, 40, 25))
                pygame.draw.ellipse(surface, (200, 170, 55), (stand_x + 60, floor_y - 25, 40, 25))
            else:
                draw_vintage_building(surface, screen_x, floor_y, s, col, level)

        elif lvl_id == 3:  
            if s["type"] == 3:
                silo_w = 120
                pygame.draw.rect(surface, (50, 50, 55), (screen_x + 30, floor_y - 320, silo_w, 320),
                                 border_top_left_radius=60, border_top_right_radius=60)
                pygame.draw.line(surface, (20, 20, 25), (screen_x + 30, floor_y - 160),
                                 (screen_x + 30 + silo_w, floor_y - 160), 4)
                pygame.draw.line(surface, (80, 80, 80), (screen_x + 90, floor_y - 320), (screen_x + 150, floor_y - 370),
                                 8)
                draw_illicit_contraband(surface, screen_x + 10, floor_y, s["detail_seed"])
            else:
                draw_industrial_building(surface, screen_x, floor_y, s, col, level)
                if s["detail_seed"] % 2 == 0:
                    draw_illicit_contraband(surface, screen_x + 25, floor_y, s["detail_seed"])

        elif lvl_id == 4:  
            pygame.draw.rect(surface, (16, 12, 18), (screen_x, floor_y - 320, s["width"], 320))

            for ly in range(floor_y - 300, floor_y, 45):
                pygame.draw.line(surface, (28, 16, 18), (screen_x, ly), (screen_x + s["width"], ly), 2)

            # Condotto
            pipe_x = screen_x + s["width"] // 2 - 45
            pygame.draw.rect(surface, (45, 50, 45), (pipe_x, floor_y - 250, 90, 110), border_radius=15)
            pygame.draw.circle(surface, (8, 10, 8), (pipe_x + 45, floor_y - 195), 32)

            # Sporco
            slime_pulse = int(math.sin(pygame.time.get_ticks() * 0.007 + s["detail_seed"]) * 12) + 12
            pygame.draw.rect(surface, (45, 175, 100), (pipe_x + 25, floor_y - 195, 40, 200 + slime_pulse),
                             border_radius=6)

            # Muschio
            pygame.draw.ellipse(surface, (60, 210, 150), (pipe_x - 30, floor_y - 50, 24, 12))
            pygame.draw.ellipse(surface, (60, 210, 150), (pipe_x + 100, floor_y - 70, 16, 10))

            # Ratti 
            time_blink = pygame.time.get_ticks() % 3000
            if time_blink > 350:  
                eye_color = (255, 30, 30) if s["detail_seed"] % 2 == 0 else (240, 210, 30)
                # Coppia occhi 1
                pygame.draw.circle(surface, eye_color, (screen_x + 35, floor_y - 120), 4)
                pygame.draw.circle(surface, eye_color, (screen_x + 47, floor_y - 120), 4)
                # Coppia occhi 2 in basso
                pygame.draw.circle(surface, eye_color, (screen_x + s["width"] - 50, floor_y - 45), 3)
                pygame.draw.circle(surface, eye_color, (screen_x + s["width"] - 42, floor_y - 45), 3)

            if s["type"] == 2:
                shelter_w = 190
                pygame.draw.rect(surface, (40, 25, 20), (screen_x + 10, floor_y - 230, shelter_w, 230),
                                 border_top_left_radius=70, border_top_right_radius=70)
                # Forno a legna 
                pygame.draw.circle(surface, (220, 75, 15), (screen_x + 10 + shelter_w // 2, floor_y - 55), 38)
                pygame.draw.circle(surface, (250, 170, 30), (screen_x + 10 + shelter_w // 2, floor_y - 50), 24)
                pygame.draw.rect(surface, (15, 15, 15), (screen_x + 10 + shelter_w // 2 - 45, floor_y - 35, 90, 40))
                # Insegna
                draw_pizzeria_sign(surface, screen_x + 10, floor_y, {"width": shelter_w, "height": 230},
                                   "PIZZA BUIA SOTTO", level)

        elif lvl_id == 5:  
            w, h = s["width"], s["height"]

            # Strutture
            pygame.draw.rect(surface, (95, 90, 85), (screen_x, floor_y - h, w, h))
            pygame.draw.rect(surface, (55, 52, 50), (screen_x, floor_y - h, w, h), 3)

            # Crepe sulla facciata 
            pygame.draw.line(surface, (45, 42, 40), (screen_x + 40, floor_y - h + 30),
                             (screen_x + 90, floor_y - h + 120), 3)
            pygame.draw.line(surface, (45, 42, 40), (screen_x + 90, floor_y - h + 120),
                             (screen_x + 70, floor_y - h + 190), 2)

            # Tondini di ferro 
            for rebar_x in range(screen_x + 25, screen_x + w - 10, 45):
                bend_x = int(math.sin(rebar_x) * 15)
                pygame.draw.line(surface, (140, 70, 45), (rebar_x, floor_y - h), (rebar_x + bend_x, floor_y - h - 35),
                                 4)
                pygame.draw.line(surface, (110, 50, 30), (rebar_x, floor_y - h), (rebar_x + bend_x, floor_y - h - 35),
                                 1)

            # Impalcature di legno 
            scaff_x = screen_x - 15
            pygame.draw.line(surface, (115, 80, 50), (scaff_x, floor_y), (scaff_x, floor_y - h - 15), 6)
            pygame.draw.line(surface, (115, 80, 50), (screen_x + w + 15, floor_y),
                             (screen_x + w + 15, floor_y - h - 15), 6)
            for step_y in range(floor_y - 60, floor_y - h, -80):
                # Asse orizzontale
                pygame.draw.line(surface, (115, 80, 50), (scaff_x, step_y), (screen_x + w + 15, step_y), 5)
                # Sicurezza instabile
                pygame.draw.line(surface, (85, 55, 30), (scaff_x, step_y), (screen_x + w + 15, step_y - 40), 3)
                pygame.draw.line(surface, (85, 55, 30), (scaff_x, step_y - 40), (screen_x + w + 15, step_y), 3)

            # Calcinacci
            pygame.draw.ellipse(surface, (140, 135, 130), (screen_x + 20, floor_y - 18, 35, 18))
            pygame.draw.ellipse(surface, (120, 115, 110), (screen_x + 45, floor_y - 14, 35, 16))
            pygame.draw.rect(surface, (150, 85, 55), (screen_x + w - 60, floor_y - 25, 20, 12))
            pygame.draw.rect(surface, (150, 85, 55), (screen_x + w - 55, floor_y - 37, 20, 12))

            if s["type"] == 2:
                draw_pizzeria_sign(surface, screen_x, floor_y, s, "PIZZERIA DELL'ABUSO", level)
                pygame.draw.line(surface, (195, 165, 45), (screen_x - 10, floor_y - 45), (screen_x + 80, floor_y - 15),
                                 8)
                pygame.draw.line(surface, (20, 20, 20), (screen_x - 10, floor_y - 45), (screen_x + 80, floor_y - 15), 8,
                                 2)

        elif lvl_id == 6: 
            draw_vintage_building(surface, screen_x, floor_y, s, col, level, extra_decorations=True)

        elif lvl_id == 7:  
            draw_boss_mansion(surface, screen_x, floor_y, s, col, level)


running = True
while running:
    # Gestione Eventi e tasti-livelli
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running = False
        elif event.type == pygame.KEYDOWN:
            if event.key in [pygame.K_1, pygame.K_2, pygame.K_3, pygame.K_4, pygame.K_5, pygame.K_6, pygame.K_7]:
                new_lvl = int(event.unicode)
                if new_lvl != current_level_id and not transitioning:
                    target_level_id = new_lvl
                    transitioning = True

    # Gestione scorrimento 
    keys = pygame.key.get_pressed()
    cam_delta = 0
    if keys[pygame.K_LEFT] or keys[pygame.K_a]:
        cam_delta = -scroll_speed
    if keys[pygame.K_RIGHT] or keys[pygame.K_d]:
        cam_delta = scroll_speed

    camera_x += cam_delta

    # Aggiornamento particelle
    current_ptype = LEVELS[current_level_id]["particle_type"]
    for p in particles:
        p.update(cam_delta)

    # Livello attuale
    current_level = LEVELS[current_level_id]
    screen.fill(current_level["sky"])

    # Base del terreno 
    if current_level_id in [1]:  
        pygame.draw.rect(screen, (60, 75, 95), (0, 480, SCREEN_WIDTH, 240))
        for oy in range(500, 580, 20):
            pygame.draw.line(screen, (80, 95, 115), (0, oy), (SCREEN_WIDTH, oy), 2)
    elif current_level_id == 4:  # Canale d'acqua
        pygame.draw.rect(screen, (8, 16, 12), (0, 500, SCREEN_WIDTH, 220))
        # Onde di scarico verdi
        for oy in range(520, 610, 30):
            pygame.draw.line(screen, (15, 36, 22), (0, oy), (SCREEN_WIDTH, oy), 3)

    # Sfondo 
    draw_background_skyline(screen, current_level_id, camera_x)

    # Primo Piano 
    draw_foreground_level(screen, current_level_id, camera_x)

    # Pavimento stradale
    ground_y = 580
    if current_level_id == 4: ground_y = 610
    pygame.draw.rect(screen, current_level["ground"], (0, ground_y, SCREEN_WIDTH, SCREEN_HEIGHT - ground_y))
    pygame.draw.line(screen, (15, 12, 10), (0, ground_y), (SCREEN_WIDTH, ground_y), 4)

    # Pietra 
    if current_level_id in [6, 7]:
        grid_col = (35, 30, 28) if current_level_id == 6 else (45, 35, 50)
        for cx in range(-int(camera_x) % 120, SCREEN_WIDTH + 120, 120):
            pygame.draw.line(screen, grid_col, (cx, ground_y), (cx - 40, SCREEN_HEIGHT), 2)

    # Disegno delle Particelle e anti-lag
    for p in particles:
        p.draw(screen)

    # Scena
    if transitioning:
        transition_alpha += 15
        if transition_alpha >= 255:
            transition_alpha = 255
            current_level_id = target_level_id
            new_ptype = LEVELS[current_level_id]["particle_type"]
            for p in particles:
                p.reset(new_ptype, init_anywhere=True)
            transitioning = False
    else:
        if transition_alpha > 0:
            transition_alpha -= 15
            if transition_alpha < 0: transition_alpha = 0

    # Transizione cinematografica
    if transition_alpha > 0:
        overlay = pygame.Surface((SCREEN_WIDTH, SCREEN_HEIGHT))
        overlay.fill((12, 10, 8))
        overlay.set_alpha(transition_alpha)
        screen.blit(overlay, (0, 0))

        if transition_alpha > 180:
            lvl_title = font_title.render(LEVELS[target_level_id]["name"], True, (240, 215, 175))
            screen.blit(lvl_title, (SCREEN_WIDTH // 2 - lvl_title.get_width() // 2, SCREEN_HEIGHT // 2 - 40))

            sub_title = font_subtitle.render("Napoli - Anno 1946", True, (170, 135, 105))
            screen.blit(sub_title, (SCREEN_WIDTH // 2 - sub_title.get_width() // 2, SCREEN_HEIGHT // 2 + 25))

    # UI
    pygame.draw.rect(screen, (240, 230, 215), (15, 15, SCREEN_WIDTH - 30, 48), border_radius=6)
    pygame.draw.rect(screen, (90, 75, 65), (15, 15, SCREEN_WIDTH - 30, 48), 2, border_radius=6)

    ui_text = font_ui.render(
        f"ZONA ATTUALE: {LEVELS[current_level_id]['name']} | [FRECCE/WASD] Esplora | Tasti [1-7] Cambia Zona", True,
        (55, 35, 25))
    screen.blit(ui_text, (35, 28))

    pygame.display.flip()
    clock.tick(FPS)

pygame.quit()
sys.exit()
