def build_scenario_for_level(lvl_id):
    random.seed(lvl_id * 105)  # Rigenerazione
    structures = []
    current_x = -3000  # Mappa da sinistra a destra
    end_x = 6000

    while current_x < end_x:
        width = random.randint(200, 380)
        height = random.randint(220, 500)

        # Tipo di struttura:
        # 1 = Edificio / Villa
        # 2 = Pizzeria / Ufficio del Boss
        # 3 = Elemento speciale (Nave, Cantiere abusivo, Casse di contrabbando)
        rand_val = random.random()
        if rand_val < 0.22:
            struct_type = 2  # Pizzeria / Edificio chiave
        elif rand_val < 0.48:
            struct_type = 3  # Struttura speciale del livello
        else:
            struct_type = 1  # Struttura standard

        structures.append({
            "x": current_x,
            "width": width,
            "height": height,
            "type": struct_type,
            "color_offset": random.randint(-15, 15),
            "detail_seed": random.randint(0, 1000)
        })
        current_x += width - random.randint(0, 20)
    return structures


# Generazione scenari
for i in range(1, 8):
