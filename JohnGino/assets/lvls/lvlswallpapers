def draw_pizzeria_sign(surface, x, floor_y, struct, text_str, level):
    """Disegno insegna vintage"""
    w, h = struct["width"], struct["height"]

    chimney_x = x + w - 40
    chimney_y = floor_y - h - 45
    pygame.draw.rect(surface, (65, 65, 65), (chimney_x, chimney_y, 20, 45))
    pygame.draw.rect(surface, (110, 28, 18), (chimney_x - 4, chimney_y, 28, 8))

    sign_w = int(w * 0.85)
    sign_h = 44
    sign_x = x + (w - sign_w) // 2
    sign_y = floor_y - 125

    pygame.draw.rect(surface, (130, 30, 20), (sign_x, sign_y, sign_w, sign_h), border_radius=4)
    pygame.draw.rect(surface, (240, 218, 175), (sign_x + 3, sign_y + 3, sign_w - 6, sign_h - 6), border_radius=4)

    test_font_size = 24
    max_text_w = sign_w - 20

    current_font = pygame.font.SysFont("serif", test_font_size, bold=True)
    text_surf = current_font.render(text_str.upper(), True, (90, 20, 12))

    # Adattamento testo-insegna
    while text_surf.get_width() > max_text_w and test_font_size > 11:
        test_font_size -= 2
        current_font = pygame.font.SysFont("serif", test_font_size, bold=True)
        text_surf = current_font.render(text_str.upper(), True, (90, 20, 12))

    text_x = sign_x + (sign_w - text_surf.get_width()) // 2
    text_y = sign_y + (sign_h - text_surf.get_height()) // 2
    surface.blit(text_surf, (text_x, text_y))

    if level in [LEVELS[1], LEVELS[6]]:
        table_x = x + 30
        pygame.draw.line(surface, (18, 18, 18), (table_x + 20, floor_y - 25), (table_x + 20, floor_y), 3)
        pygame.draw.rect(surface, (170, 35, 25), (table_x, floor_y - 28, 40, 8))
        pygame.draw.rect(surface, (235, 235, 235), (table_x + 10, floor_y - 28, 20, 8))


def draw_vintage_building(surface, x, floor_y, struct, color, level, extra_decorations=False):
    """Costruzione palazzi d'epoca"""
    w, h = struct["width"], struct["height"]
    rect = pygame.Rect(x, floor_y - h, w, h)

    pygame.draw.rect(surface, color, rect)
    pygame.draw.rect(surface, (max(0, color[0] - 25), max(0, color[1] - 25), max(0, color[2] - 25)), rect, 2)

    window_color = (35, 30, 25)
    win_w, win_h = 16, 28
    spacing_x = 45
    spacing_y = 65
    start_y = rect.y + 40

    for wx in range(rect.x + 25, rect.x + w - 25, spacing_x):
        for wy in range(start_y, floor_y - 60, spacing_y):
            pygame.draw.rect(surface, (205, 185, 165), (wx - 3, wy - 5, win_w + 6, win_h + 8))
            pygame.draw.rect(surface, window_color, (wx, wy, win_w, win_h))
            pygame.draw.rect(surface, (40, 60, 45), (wx - 6, wy, 6, win_h))
            pygame.draw.rect(surface, (40, 60, 45), (wx + win_w, wy, 6, win_h))

    if extra_decorations and struct["detail_seed"] % 3 == 0:
        line_y = rect.y + 110
        pygame.draw.line(surface, (25, 25, 25), (rect.x, line_y), (rect.x + w, line_y + 8), 1)
        cloth_colors = [(190, 45, 45), (215, 215, 215), (65, 95, 150), (195, 175, 45)]
        for cx in range(rect.x + 20, rect.x + w - 20, 30):
            ccol = cloth_colors[cx % len(cloth_colors)]
            pygame.draw.rect(surface, ccol, (cx, line_y + 2, 12, 18))
            pygame.draw.line(surface, (0, 0, 0), (cx, line_y + 1), (cx + 12, line_y + 1), 2)

    door_w, door_h = 45, 65
    pygame.draw.rect(surface, (55, 35, 25), (rect.x + w // 2 - door_w // 2, floor_y - door_h, door_w, door_h),
                     border_top_left_radius=20, border_top_right_radius=20)
